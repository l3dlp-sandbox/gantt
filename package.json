{
	"name": "dhtmlx-gantt",
	"version": "10.0.0",
	"description": "DHTMLX Gantt - open source JavaScript Gantt chart (Community edition)",
	"type": "module",
	"main": "codebase/dhtmlxgantt.js",
	"module": "codebase/dhtmlxgantt.es.js",
	"types": "codebase/dhtmlxgantt.d.ts",
	"style": "codebase/dhtmlxgantt.css",
	"files": [
		"codebase",
		"whatsnew.md",
		"README.md",
		"LICENSE.md"
	],
	"scripts": {
		"build": "vite build && node scripts/postbuild.js",
		"watch": "vite build --watch",
		"start": "concurrently \"npm:watch\" \"node scripts/server.js\" \"vite\"",
		"server": "node scripts/server.js",
		"test": "node scripts/test.js",
		"lint": "eslint src"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/DHTMLX/gantt.git"
	},
	"author": "XB Software",
	"license": "MIT",
	"homepage": "https://dhtmlx.com/docs/products/dhtmlxGantt/",
	"keywords": [
		"gantt",
		"gantt-chart",
		"project-management",
		"javascript",
		"typescript",
		"scheduler",
		"timeline",
		"dhtmlx"
	],
	"devDependencies": {
		"chalk": "^5.3.0",
		"chokidar": "^4.0.1",
		"concurrently": "^8.2.2",
		"eslint": "^9.12.0",
		"express": "^4.21.0",
		"glob": "^13.0.0",
		"less": "^4.2.0",
		"puppeteer": "^24.15.0",
		"sirv": "^2.0.4",
		"striptags": "^3.2.0",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.8.0",
		"vite": "^7.3.5"
	}
}
